    "name": "リダイレクト設定を行う",
    "title": "リダイレクト設定を行う",
    "source_locale": "ja",
    "locale": "ja",
    "outdated": false,
    "outdated_locales": [],
    "edited_at": "2026-03-12T00:31:04Z",
